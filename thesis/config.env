# Thesis execution configuration.
# Keep this file cheap/CPU-safe by default. Switch USE_GPU=1 only after the
# Studio is moved to an RTX GPU machine.

USE_GPU=0
CPU_PREP_ONLY=1
ENABLE_AUTOSAVE=0
ENABLE_GIT_PUSH=1
RUN_CPU_INSTALLS=0

GITHUB_REPO=https://github.com/Sushruths04/Humanoid.git
HF_REPO=

# Scale knobs. Start tiny, then raise only after a full small run succeeds.
GR00T_DATA_TRAJ=200
GR00T_FT_STEPS=2000
GR00T_SAVE_INTERVAL=500
G1_TASK_ID=Isaac-PickPlace-Locomanipulation-G1-Abs-v0
G1_LANGUAGE_TASK_ID=Humanoid-G1-Language-PickPlace-v0
G1_NUM_ENVS=512
G1_MAX_ITERS=300
LANGUAGE_EMBEDDING_DIM=16

